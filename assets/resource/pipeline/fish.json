{
   "启动钓鱼": {
      "rate_limit": 200,
      "recognition": "DirectHit",
      "next": "初始状态"
   },
   "初始状态": {
      "rate_limit": 500,
      // 有按钮就按 F
      "recognition": {
         "type": "FeatureMatch",
         "param": {
            "roi": [904, 610, 318, 100],
            "template": "fish/初始按钮排.png"
         }
      },
      "action": {
         "type": "ClickKey",
         "param": {
            "key": 70 // F
         }
      },
      "next": ["上鱼", "获鱼", "初始状态"]
   },
   "上鱼": {
      "recognition": {
         "type": "OCR",
         "param": {
            "roi": [312, 82, 650, 28],
            "expected": ["鱼耐力", "鱼线"]
         }
      },
      "next": "溜鱼"
   },
   "溜鱼": {
      "rate_limit": 200,
      "timeout": 6000,
      "on_error": "初始状态",
      "recognition": "DirectHit",
      "action": {
         "type": "Custom",
         "param": {
            "custom_action": "fish_溜鱼"
         }
      },
      "next": ["获鱼", "溜鱼"]
   },
   "获鱼": {
      "recognition": {
         "type": "OCR",
         "param": {
            "roi": [550, 630, 160, 46],
            "expected": "点击空白区域关闭"
         }
      },
      "action": {
         "type": "ClickKey",
         "param": {
            "key": 27 // ESC
         }
      },
      "next": "初始状态"
   }
}
