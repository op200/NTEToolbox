{
   "启动钓鱼": {
      "rate_limit": 200,
      "recognition": "DirectHit",
      "next": ["上鱼", "无饵", "获鱼", "初始状态"]
   },
   "初始状态": {
      "rate_limit": 400,
      // 有按钮就按 F
      "recognition": {
         "type": "FeatureMatch",
         "param": {
            "roi": [1144, 606, 84, 96],
            "template": "fish/钓鱼按钮.png",
            "ratio": 0.86
         }
      },
      "action": {
         "type": "ClickKey",
         "param": {
            "key": 70 // F
         }
      },
      "next": ["上鱼", "无饵", "获鱼", "初始状态"]
   },
   "无饵": {
      "rate_limit": 100,
      "recognition": {
         "type": "OCR",
         "param": {
            "roi": [520, 342, 240, 36],
            "expected": "需要装备鱼饵才可以钓鱼"
         }
      },
      "focus": {
         "Node.Action.Succeeded": {
            "content": "钓鱼结束: 鱼饵用完",
            "display": ["log", "notification"]
         }
      }
   },
   "上鱼": {
      "rate_limit": 200,
      "recognition": {
         "type": "OCR",
         "param": {
            "roi": [312, 82, 650, 28],
            "expected": ["鱼耐力", "鱼线"]
         }
      },
      "next": "溜鱼"
   },
   "溜鱼": {
      "rate_limit": 200,
      "timeout": 6000,
      "on_error": "初始状态",
      "recognition": "DirectHit",
      "action": {
         "type": "Custom",
         "param": {
            "custom_action": "fish_溜鱼"
         }
      },
      "next": ["获鱼", "溜鱼"]
   },
   "获鱼": {
      "rate_limit": 500,
      "recognition": {
         "type": "OCR",
         "param": {
            "roi": [550, 630, 180, 46],
            "expected": "点击空白区域关闭"
         }
      },
      "action": {
         "type": "ClickKey",
         "param": {
            "key": 27 // ESC
         }
      },
      "next": "初始状态"
   }
}
