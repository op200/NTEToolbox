{
   "interface_version": 2,
   "name": "NTEToolbox",
   "description": "异环工具箱",
   "license": "AGPLv3",
   "github": "https://github.com/op200/NTEToolbox",
   "version": "0.2.9",
   "resource": [
      {
         "name": "默认",
         "path": ["./resource"]
      }
   ],
   "agent": {
      "child_exec": "python",
      "child_args": ["-u", "-m", "agent"]
   },
   "controller": [
      {
         "name": "桌面端_PostMessage（默认）",
         "type": "Win32",
         "permission_required": true,
         "win32": {
            "class_regex": "UnrealWindow",
            "window_regex": "^\\s*(异环|NTE)\\s*$",
            "screencap": "FramePool",
            "mouse": "PostMessage",
            "keyboard": "PostMessage"
         }
      },
      {
         "name": "桌面端_PostMessageWithWindowPos",
         "type": "Win32",
         "permission_required": true,
         "win32": {
            "class_regex": "UnrealWindow",
            "window_regex": "^\\s*(异环|NTE)\\s*$",
            "screencap": "FramePool",
            "mouse": "PostMessageWithCursorPos",
            "keyboard": "PostMessageWithWindowPos"
         }
      },
      {
         "name": "桌面端_Seize",
         "type": "Win32",
         "win32": {
            "class_regex": "UnrealWindow",
            "window_regex": "^\\s*(异环|NTE)\\s*$",
            "screencap": "FramePool",
            "mouse": "Seize",
            "keyboard": "Seize"
         }
      }
   ],
   "task": [
      {
         "name": "钓鱼",
         "entry": "钓鱼01",
         "option": ["钓鱼设置"]
      },
      {
         "name": "弹钢琴（键盘输入）",
         "entry": "弹钢琴_keybord",
         "option": ["弹钢琴_keybord_设置"]
      }
   ],
   "option": {
      "钓鱼设置": {
         "type": "input",
         "inputs": [
            {
               "name": "溜鱼_midpoint_pix_range",
               "label": "溜鱼中点停顿范围（pix）",
               "pipeline_type": "int",
               "default": "5"
            },
            {
               "name": "溜鱼_midpoint_sleep_time",
               "label": "溜鱼中点停顿时间（ms）",
               "pipeline_type": "int",
               "default": "5"
            }
         ],
         "pipeline_override": {
            "溜鱼": {
               "action": {
                  "param": {
                     "custom_action_param": {
                        "溜鱼_midpoint_pix_range": "{溜鱼_midpoint_pix_range}",
                        "溜鱼_midpoint_sleep_time": "{溜鱼_midpoint_sleep_time}"
                     }
                  }
               }
            }
         }
      },
      "弹钢琴_keybord_设置": {
         "type": "input",
         "inputs": [
            {
               "name": "midi_path",
               "label": "MIDI 文件路径",
               "pipeline_type": "string"
            },
            {
               "name": "bpm",
               "label": "默认 BPM",
               "pipeline_type": "string"
            },
            {
               "name": "piano_mode",
               "label": "钢琴模式（只能填 21 或 36）",
               "pipeline_type": "string",
               "default": "36"
            },
            {
               "name": "timeout_mode",
               "label": "超时模式（只能填 同步时轴 或 速率不变）",
               "pipeline_type": "string",
               "default": "速率不变"
            }
         ],
         "pipeline_override": {
            "启动弹钢琴_keybord": {
               "action": {
                  "param": {
                     "custom_action_param": {
                        "midi_path": "{midi_path}",
                        "bpm": "{bpm}",
                        "piano_mode": "{piano_mode}",
                        "timeout_mode": "{timeout_mode}"
                     }
                  }
               }
            }
         }
      }
   }
}
