{
   // 本文件主要定义了通用 UI 的行为和显示内容
   // 可参考文档和示例添加更多您需要的功能
   // 文档：https://maafw.xyz/docs/3.3-ProjectInterfaceV2
   // 示例：https://github.com/MaaXYZ/MaaFramework/blob/main/sample/interface.json
   "interface_version": 2,
   "name": "NTEToolbox",
   "description": "NTE Toolbox",
   "contact": "",
   "license": "MIT",
   "welcome": "首次使用！欢迎使用 MAA!",
   // 填写项目地址和版本号可实现自动更新功能
   "github": "https://github.com/op200/NTEToolbox",
   "version": "0.1.0",
   // Mirror酱为第三方分发服务，新项目默认关闭
   // 若有需要请联系 Mirror酱 开通，直接自行开启是无法使用的
   // "mirrorchyan_rid": "MaaXXX",
   // "mirrorchyan_multiplatform": true,
   "controller": [
      {
         "name": "桌面端",
         "type": "Win32",
         "win32": {
            "class_regex": ".*",
            "window_regex": "异环\\s*",
            // 截图及控制方式，请根据项目实际情况修改
            // 文档: https://maafw.xyz/docs/2.4-ControlMethods
            "screencap": "FramePool", // 截图方式
            "mouse": "PostMessage", // 鼠标控制方式
            "keyboard": "PostMessage" // 键盘控制方式
         }
      }
   ],
   "resource": [
      {
         "name": "默认",
         "path": ["./resource"]
      }
   ],
   "agent": {
      "child_exec": "python",
      "child_args": ["../agent/main.py"]
   },
   "task": [
      {
         "name": "钓鱼01",
         "entry": "钓鱼01"
      }
   ]
}
