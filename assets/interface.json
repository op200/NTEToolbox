{
   // 本文件主要定义了通用 UI 的行为和显示内容
   // 可参考文档和示例添加更多您需要的功能
   // 文档：https://maafw.xyz/docs/3.3-ProjectInterfaceV2
   // 示例：https://github.com/MaaXYZ/MaaFramework/blob/main/sample/interface.json
   "interface_version": 2,
   "name": "NTEToolbox",
   "description": "异环工具箱",
   "license": "AGPLv3",
   "github": "https://github.com/op200/NTEToolbox",
   "version": "0.1.8",
   "mirrorchyan_multiplatform": false,
   "controller": [
      {
         "name": "桌面端",
         "type": "Win32",
         "win32": {
            "class_regex": ".*",
            "window_regex": "异环\\s*",
            // https://maafw.xyz/docs/2.4-ControlMethods
            "screencap": "FramePool",
            "mouse": "PostMessage",
            "keyboard": "PostMessage"
         }
      }
   ],
   "resource": [
      {
         "name": "默认",
         "path": ["./resource"]
      }
   ],
   "agent": {
      "child_exec": "python",
      "child_args": ["-u", "./agent/main.py"]
   },
   "task": [
      {
         "name": "钓鱼",
         "entry": "钓鱼01"
      }
   ]
}
